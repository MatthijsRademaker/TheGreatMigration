#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
source "$ROOT/scripts/.versions"
source "$ROOT/scripts/lib/docker-verification.sh"

WORKSPACE="$(verification_workspace_root)"
export TMPDIR="${TMPDIR:-$WORKSPACE/.cache/tmp}"
mkdir -p "$TMPDIR"

# --- Frontend checks ---
echo "[scripts/check] Running frontend checks..."
verification_reset
verification_workdir "$WORKSPACE"
verification_add_arg -v "$WORKSPACE:$WORKSPACE"
verification_add_cache npm /cache/npm npm_config_cache
verification_add_env npm_config_update_notifier=false
verification_add_env npm_config_package_lock=false
verification_add_env npm_config_legacy_peer_deps=true

if ! verification_run_container "$NODE24_IMAGE" \
  sh -c 'cd frontend && npm install --no-audit --no-fund --package-lock=false --legacy-peer-deps && npm run check'; then
  echo "[scripts/check] Frontend check FAILED" >&2
  exit 1
fi
echo "[scripts/check] Frontend check passed."

# --- Backend checks ---
echo "[scripts/check] Running backend checks..."
verification_reset
verification_workdir "$WORKSPACE"
verification_add_arg -v "$WORKSPACE:$WORKSPACE"
verification_add_env GOCACHE=/workspace/.cache/go-cache
verification_add_env GOPATH=/workspace/.cache/go

if ! verification_run_container "$GO_IMAGE" \
	sh -c 'cd backend && go mod tidy && go vet ./... && go build ./... && echo "[scripts/check] Checking OpenAPI snapshot consistency..." && go run ./cmd/openapi-gen | diff - ../frontend/openapi-snapshot.json'; then
  echo "[scripts/check] Backend check FAILED" >&2
  echo "[scripts/check] If the OpenAPI snapshot is stale, run: cd frontend && npm run regen:api" >&2
  exit 1
fi
echo "[scripts/check] Backend check passed."

echo "[scripts/check] All checks passed."
