{
  "name": "the-great-migration",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "check": "vue-tsc --noEmit",
    "test": "vitest run",
    "refresh:openapi-snapshot": "bash ./scripts/refresh-openapi-snapshot.sh",
    "generate:api": "node ./scripts/generate-api.mjs",
    "regen:api": "npm run refresh:openapi-snapshot && npm run generate:api",
    "shadcn:info": "shadcn-vue info --json"
  },
  "dependencies": {
    "@internationalized/date": "^3.9.1",
    "@lucide/vue": "^1.18.0",
    "@pinia/colada": "1.3.1",
    "@vue/test-utils": "^2.4.6",
    "@vueuse/core": "^14.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "pinia": "3.0.4",
    "reka-ui": "^2.9.10",
    "tailwind-merge": "^3.6.0",
    "vue": "^3.5.13",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "0.98.2",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^24.0.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "shadcn-vue": "^2.7.4",
    "tailwindcss": "^4.0.0",
    "tw-animate-css": "^1.4.0",
    "jsdom": "^25.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.0",
    "vitest": "^2.1.8",
    "vue-tsc": "^2.2.0"
  }
}
